use Stdlib.

witness Display Text :=
  { display := λt. prim_show t
  }

witness Display Char :=
  { display := λt. prim_show t
  }

external parse_number :: Text -> Perhaps Int

start := lambda _.
  let t = "hello, world" in
  let s = Text.to_list t in
  print_endline "Text `Text.from_list s`."

  print_endline "`List.concat (Cons "A" (List.singleton "B"))`"
