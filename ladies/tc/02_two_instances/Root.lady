(* 02: Instance selection among several concrete witnesses. *)
(* The same method `show` must resolve to the Int witness or the Bool witness *)
(* depending on the argument type at each call site. *)

signature Show ::= ∀α.
  { show :: α -> Text
  }

witness Show Int :=
  { show := λn. prim_show n
  }

witness Show Bool :=
  { show := λb. if b then "true" else "false"
  }

start :: Int -> Unit := λ_.
  print_endline "##TC"
  print_endline (show 7)
  print_endline (show true)
