(* String interpolation. Each `expr` segment is rendered via a Display instance. *)

signature Display ::= ∀α.
  { display :: α -> Text
  }

witness Display Int  := { display := λn. prim_show n }
witness Display Text := { display := λt. t }

greet :: Text -> Int -> Text := λname age.
  "Hello `name`, next year you will be `age + 1`."

start :: Int -> Unit := λ_.
  print_endline "##TC"
  print_endline (greet "Ada" 36)
