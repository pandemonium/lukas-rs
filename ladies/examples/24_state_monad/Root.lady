(* The State monad from the standard library: thread mutable state through a
   pure computation. *)

use Stdlib.

tick :: State Int Int :=
  let* n = get in
  let* _ = put (n + 1) in
  pure n

start :: Int -> Unit := λ_.
  print_endline "##TC"
  print_endline (prim_show (eval tick 41))   (* value read: 41 *)
  print_endline (prim_show (exec tick 41))   (* final state: 42 *)
