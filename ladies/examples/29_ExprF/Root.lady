(* Pattern-functor / recursion-schemes style. `ExprF` factors the recursive
   positions of an expression AST out into the parameter `r`, so the recursion
   structure comes entirely from its `Functor` instance. `Expr` ties the knot,
   and `foldExpr` is the catamorphism -- every fold below is just an algebra. *)

use Stdlib.

ExprF ::= ∀name α r.
    Var    α name
  | Lit    α Constant
  | Lambda α name r
  | Apply  α r r

Constant ::=
  MkInt Int | MkText Text

witness ∀name α. Functor (ExprF name α) :=
  { fmap := λf fa.
      deconstruct fa into
        Var a name      -> Var a name
      | Lit a const     -> Lit a const
      | Lambda a name r -> Lambda a name (f r)
      | Apply a r s     -> Apply a (f r) (f s)
  }

(* newtype Expr name a = Expr { unExpr :: ExprF name a (Expr name a) } *)
Expr ::= ∀name a. MkExpr (ExprF name a (Expr name a))

(* foldExpr alg = go where go (Expr e) = alg (fmap go e) *)
foldExpr :: ∀name a r. (ExprF name a r -> r) -> Expr name a -> r :=
  λalg (MkExpr e). alg (fmap (foldExpr alg) e)

(* `first f` from Data.Bifunctor, over the annotation slot (hand-written) *)
firstExpr :: ∀name a b r. (a -> b) -> ExprF name a r -> ExprF name b r :=
  λf e.
    deconstruct e into
      Var a name      -> Var (f a) name
    | Lit a const     -> Lit (f a) const
    | Lambda a name r -> Lambda (f a) name r
    | Apply a r s     -> Apply (f a) r s

(* mapAnnotation f = foldExpr (Expr . first f) *)
mapAnnotation :: ∀name a b. (a -> b) -> Expr name a -> Expr name b :=
  λf. foldExpr (compose MkExpr (firstExpr f))

(* stripAnnotations = mapAnnotation (const ()) *)
stripAnnotations :: ∀name a. Expr name a -> Expr name Unit :=
  mapAnnotation (const ())

(* --- some algebras (each is just an `ExprF _ _ r -> r`) --- *)

countAlg :: ∀name a. ExprF name a Int -> Int :=
  λe.
    deconstruct e into
      Var a name      -> 1
    | Lit a const     -> 1
    | Lambda a name r -> r + 1
    | Apply a r s     -> r + s + 1

countNodes :: ∀name a. Expr name a -> Int := foldExpr countAlg

sumAlg :: ∀name. ExprF name Int Int -> Int :=
  λe.
    deconstruct e into
      Var a name      -> a
    | Lit a const     -> a
    | Lambda a name r -> a + r
    | Apply a r s     -> a + r + s

sumAnnotations :: ∀name. Expr name Int -> Int := foldExpr sumAlg

(* The AST for `(λx. x) 1`, built bottom-up (annotations are the Ints). *)
xVar  :: Expr Text Int := MkExpr (Var 3 "x")
idFun :: Expr Text Int := MkExpr (Lambda 7 "x" xVar)
lit1  :: Expr Text Int := MkExpr (Lit 5 (MkInt 1))

(* The top `Apply` node, one argument per line -- Marmelade's layout is *)
(* offside, so an application continues across lines when the head is on *)
(* its own line and each argument is indented past it and aligned.       *)
appNode :: ExprF Text Int (Expr Text Int) :=
  Apply
    9
    idFun
    lit1

sample :: Expr Text Int := MkExpr appNode

start :: Int -> Unit := λ_.
  print_endline "##TC"
  print_endline (prim_show (countNodes sample))                      (* 4 *)
  print_endline (prim_show (sumAnnotations sample))                  (* 24 *)
  print_endline (prim_show (countNodes (stripAnnotations sample)))   (* 4 *)
  print_endline (prim_show (sumAnnotations (mapAnnotation (λn. n + 1) sample)))  (* 28 *)
